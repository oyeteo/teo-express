# Supabase Configuration
NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# App Configuration
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Admin studio (/admin) — set a strong password and a random 32+ char secret
TEO_ADMIN_PASSWORD=change-me
TEO_ADMIN_SESSION_SECRET=change-me-to-a-long-random-string

# Storage bucket for uploads from the admin UI and CLI.
# Must be private; TEO.EXPRESS serves recipients short-lived signed URLs.
SUPABASE_STORAGE_BUCKET=client-files

# Optional guardrail for the internal browser uploader; use the CLI for large files.
TEO_ADMIN_MAX_UPLOAD_BYTES=104857600
